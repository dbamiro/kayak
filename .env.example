# Copy to .env and adjust for local PostgreSQL.
DATABASE_URL=postgresql://dmv_user:dmv_pass@localhost:5432/dmv_apartments

# Crawler defaults (override per run if needed)
CRAWLER_USER_AGENT=DMV-ApartmentIntel/0.1 (+research)
CRAWLER_TIMEOUT_SECONDS=30
PLAYWRIGHT_HEADLESS=true

# Optional: comma-separated proxy URLs for crawler (future use)
# HTTP_PROXY=

# API
API_HOST=0.0.0.0
# Respectful crawling defaults (see README — obey robots/terms)
CRAWLER_MAX_RETRIES=2
CRAWLER_RETRY_BACKOFF_SECONDS=1.5
CRAWLER_MIN_INTERVAL_MS=500
PLAYWRIGHT_SCREENSHOT_ON_ERROR=false
