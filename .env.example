# Copy to .env and adjust.
#   cp .env.example .env

# --- Phase 1: auth + API ---
# Local dev: any non-empty string works; generate for staging/prod:
#   openssl rand -hex 32
JWT_SECRET=local-dev-change-me-not-for-production
JWT_EXPIRES_MINUTES=60
JWT_REFRESH_DAYS=14
# Local dev: true allows X-User-Id header without Bearer for some routes (e.g. deal report dev).
# Production: false (default in app/config.py if unset).
MOCK_AUTH_MODE=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# For local verified-data import, use the same email you register/login with.
# Keep passwords out of .env; pass ADMIN_PASSWORD only in your shell.
ADMIN_EMAILS=

# Incentives: include demo specials in search/listings (true locally, false in production)
# Set false and restart the API for the REAL_DATA_QUICKSTART.md workflow.
SHOW_DEMO_DATA=true
APP_ENV=development

DATABASE_URL=postgresql://dmv_user:dmv_pass@localhost:5432/dmv_apartments

# Isolated DB for pytest integration tests (@pytest.mark.db). Never point at dev/prod data.
TEST_DATABASE_URL=postgresql://dmv_user:dmv_pass@localhost:5432/kayak_test

# Crawler defaults (override per run if needed)
CRAWLER_USER_AGENT=DMV-ApartmentIntel/0.1 (+research)
CRAWLER_TIMEOUT_SECONDS=30
PLAYWRIGHT_HEADLESS=true

# Crawler proxy (optional; disabled by default — see docs/CRAWLER_PROXY.md).
# Public pages only. Never used to bypass Cloudflare/CAPTCHA/logins/blocks.
# Placeholders only — never commit real credentials.
PROXY_ENABLED=false
PROXY_PROVIDER=decodo
# e.g. http://USERNAME:PASSWORD@gate.decodo.com:7000 (Decodo)
#      http://USERNAME:PASSWORD@brd.superproxy.io:33335 (Bright Data)
PROXY_HTTP_URL=
PROXY_HTTPS_URL=
PROXY_MAX_RETRIES=1
PROXY_TIMEOUT_SECONDS=20
PROXY_MONTHLY_GB_BUDGET=2

# API
API_HOST=0.0.0.0
# Respectful crawling defaults (see README — obey robots/terms)
CRAWLER_MAX_RETRIES=2
CRAWLER_RETRY_BACKOFF_SECONDS=1.5
CRAWLER_MIN_INTERVAL_MS=500
PLAYWRIGHT_SCREENSHOT_ON_ERROR=false

# Monetization / Stripe (optional — leave empty for local mock checkout)
# Production: set STRIPE_* keys, APP_ENV=production, MOCK_CHECKOUT_MODE=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_HUNT_PASS_30=
STRIPE_PRICE_PREMIUM_PLUS_30=
STRIPE_PRICE_CONCIERGE_ONE_TIME=
MOCK_CHECKOUT_MODE=true
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# Limits (compare / alerts)
FREE_ALERT_LIMIT=1
PAID_ALERT_LIMIT=20
FREE_COMPARE_LIMIT=2
PAID_COMPARE_LIMIT=10

# Rate limits (requests per IP per minute; 0 = disable)
RATE_LIMIT_AUTH_REGISTER_PER_MINUTE=5
RATE_LIMIT_AUTH_LOGIN_PER_MINUTE=20
RATE_LIMIT_INCENTIVE_SUBMIT_PER_MINUTE=6
RATE_LIMIT_ADMIN_PER_MINUTE=120

# Scheduled jobs (production cron — see docs/SCHEDULED_JOBS.md)
ENABLE_DAILY_CRAWL=false
PENDING_INCENTIVE_TTL_DAYS=90

# Frontend (Next.js in ./web) — must match browser-reachable API URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Kayak DMV
