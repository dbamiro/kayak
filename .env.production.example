# Production environment template — copy to .env on the server (never commit secrets).
# See docs/PRODUCTION_DEPLOY.md and PRODUCTION_CHECKLIST.md

APP_ENV=production
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32
JWT_EXPIRES_MINUTES=60
JWT_REFRESH_DAYS=14

MOCK_AUTH_MODE=false
MOCK_CHECKOUT_MODE=false
SHOW_DEMO_DATA=false

# Postgres (docker-compose.prod.yml postgres service)
POSTGRES_USER=kayak
POSTGRES_PASSWORD=REPLACE_WITH_strong_password
POSTGRES_DB=kayak_prod

# API/jobs containers — hostname "postgres" on Docker network
DATABASE_URL=postgresql://kayak:REPLACE_WITH_strong_password@postgres:5432/kayak_prod

# Host-side migrate scripts (127.0.0.1 — postgres port bound to localhost)
MIGRATE_DATABASE_URL=postgresql://kayak:REPLACE_WITH_strong_password@127.0.0.1:5432/kayak_prod

CORS_ORIGINS=https://your-app.example.com
APP_BASE_URL=https://your-app.example.com
API_BASE_URL=https://api.your-app.example.com

ADMIN_EMAILS=ops@your-company.com

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_HUNT_PASS_30=price_...
STRIPE_PRICE_PREMIUM_PLUS_30=
STRIPE_PRICE_CONCIERGE_ONE_TIME=

# Rate limits (requests per IP per minute)
RATE_LIMIT_AUTH_REGISTER_PER_MINUTE=5
RATE_LIMIT_AUTH_LOGIN_PER_MINUTE=20
RATE_LIMIT_INCENTIVE_SUBMIT_PER_MINUTE=6
RATE_LIMIT_ADMIN_PER_MINUTE=120

# Scheduled jobs (production cron — see docs/SCHEDULED_JOBS.md)
ENABLE_DAILY_CRAWL=false
PENDING_INCENTIVE_TTL_DAYS=90
CRAWL_LIMIT=20
CRAWLER_USER_AGENT=Kayak-DMV/1.0 (+https://your-app.example.com/contact)

# Frontend build-time (web/)
NEXT_PUBLIC_API_BASE_URL=https://api.your-app.example.com
NEXT_PUBLIC_APP_NAME=Kayak DMV
